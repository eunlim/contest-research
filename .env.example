# ── Claude API ────────────────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력

# ── Google Sheets ─────────────────────────────────────────────
# 스프레드시트 URL의 /d/ 뒤 긴 문자열
# 예: https://docs.google.com/spreadsheets/d/【여기】/edit
GOOGLE_SHEET_ID=여기에_스프레드시트_ID_입력

# 결과를 저장할 시트(탭) 이름 (기본값: ideas)
SHEET_NAME=ideas
